# Linux example
STOCK_ADMIN_DB_URL=jdbc:sqlite:/root/data/stock_stat.db
STOCK_ADMIN_QUOTE_60_DB_URL=jdbc:sqlite:/root/data/stock_quote_60_cnfin.db
STOCK_ADMIN_KLINE_CACHE_DIR=runtime/kline-cache

# stock-admin/bin/start.sh also reads ../stock_cron/.env when stock-admin/.env is absent.
# If only STOCK_STAT_DB_PATH is set, start.sh derives STOCK_ADMIN_DB_URL automatically.

# Windows example
# STOCK_ADMIN_DB_URL=jdbc:sqlite:.\data\stock_stat.db
# STOCK_ADMIN_QUOTE_60_DB_URL=jdbc:sqlite:.\data\stock_quote_60_cnfin.db
# STOCK_ADMIN_KLINE_CACHE_DIR=runtime\kline-cache
