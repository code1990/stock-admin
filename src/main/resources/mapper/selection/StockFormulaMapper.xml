<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.stockadmin.selection.mapper.StockFormulaMapper">

    <select id="selectByName" resultType="com.stockadmin.selection.domain.StockFormulaDefinition">
        SELECT id, name, code
        FROM t_stock_formula
        WHERE name = #{name}
          AND name IS NOT NULL
          AND TRIM(name) &lt;&gt; ''
          AND code IS NOT NULL
          AND TRIM(code) &lt;&gt; ''
        LIMIT 1
    </select>

</mapper>
